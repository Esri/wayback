{
    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "allowJs": false,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "baseUrl": "./",
        "forceConsistentCasingInFileNames": true,
        // Specify library type definitions to be included in the compilation.
        // "lib": ["DOM", "DOM.Iterable", "ES2023"],
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        // The module system to use for compilation.
        // Here, ES modules are targeted (ESNext) to enable top-level await and dynamic imports.
        "module": "ES2022",
        // Respects package.json's "exports" conditions.
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "noImplicitAny": true,
        "outDir": "./build/",
        "preserveConstEnums": true,
        "removeComments": true,
        "sourceMap": false,
        "target": "es2020",
        "resolveJsonModule": true,
        "typeRoots": [ "./src/types", "./node_modules/@types"],
        // "lib": [ "es2020", "dom" ],
        "paths": {
            "@components/*": ["./src/components/*"],
            "@constants/*": ["./src/constants/*"],
            "@contexts/*": ["./src/contexts/*"],
            "@hooks/*": ["./src/hooks/*"],
            "@services/*": ["./src/services/*"],
            "@store/*": ["./src/store/*"],
            "@styles/*": ["./src/style/*"],
            "@typings/*": ["./src/types/*"],
            "@utils/*": ["./src/utils/*"],
        }

    },
    "exclude": ["node_modules", "typings"],
    "include": [
        "./src/**/**/*"
    ]
}